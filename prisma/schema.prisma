generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String
  avatar        String?
  role          Role     @default(AGENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentProfile  AgentProfile?
  leads         PolicyLead[]
}

model AgentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankCustomerId String?
  location       String?
  language       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PolicyLead {
  id            String           @id @default(cuid())
  agentId       String
  agent         User             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  householdName String
  phone         String?
  income        Int?
  familySize    Int?
  messages      Message[]
  status        LeadStatus       @default(NEW)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  dateOfBirth   DateTime?
  followUpAt    DateTime?
  reminders     Reminder[]
  birthdayReminders BirthdayReminder[]
  issuances     PolicyIssuance[]

  // Indexes
  @@unique([agentId, phone])

  @@index([agentId, status, followUpAt])
  @@index([status])
  @@index([followUpAt])
  @@index([agentId, createdAt])
}

model PolicyIssuance {
  id             String          @id @default(cuid())
  leadId         String
  lead           PolicyLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  policyName     String
  policyProvider String?
  premiumAmount  Int?
  issuedAt       DateTime        @default(now())
  expiresAt      DateTime?
  status         IssuanceStatus  @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  nextPremiumDue DateTime?

  // Indexes
  @@index([leadId])
}

model Message {
  id        String      @id @default(cuid())
  leadId    String
  lead      PolicyLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  policies  Json?
  createdAt DateTime    @default(now())

  // Indexes
  @@index([leadId, createdAt])
}

model Reminder {
  id          String       @id @default(cuid())
  leadId      String
  lead        PolicyLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        ReminderType
  scheduledAt DateTime
  note        String?
  isDone      Boolean      @default(false)
  createdAt   DateTime     @default(now())

  // Indexes
  @@index([leadId])
  @@index([scheduledAt])
}

model BirthdayReminder {
  id            String     @id @default(cuid())
  leadId        String
  lead          PolicyLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  dateOfBirth   DateTime
  daysUntil     Int
  isToday       Boolean    @default(false)
  wishSent      Boolean    @default(false)
  refreshedAt   DateTime   @default(now())

  // Indexes
  @@index([leadId])
}

enum ReminderType {
  FOLLOWUP
  BIRTHDAY
}

enum MessageRole {
  AGENT
  AI
}

enum Role {
  AGENT
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  POLICY_ISSUED
  REJECTED
}

enum IssuanceStatus {
  ACTIVE
  EXPIRED
  CLAIMED
}