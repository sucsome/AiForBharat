generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique  // Clerk's user ID — links auth to our DB
  email         String   @unique
  name          String
  avatar        String?
  role          Role     @default(AGENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentProfile  AgentProfile?
  leads         PolicyLead[]
}

model AgentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankCustomerId String?  // ID assigned by the bank partner that onboarded this agent
  location       String?  // Village/district they operate in
  language       String?  // Primary language they speak
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// A household flagged by an agent as interested in insurance
model PolicyLead {
  id            String           @id @default(cuid())
  agentId       String
  agent         User             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  householdName String
  phone         String?
  income        Int?             // Monthly income in INR
  familySize    Int?
  messages      Message[]
  status        LeadStatus       @default(NEW)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  dateOfBirth   DateTime?
  followUpAt    DateTime?
  reminders     Reminder[]
  birthdayReminders BirthdayReminder[]

  issuances     PolicyIssuance[] // One household can have multiple policies issued
}

// Tracks which policy was actually issued to a household
// Policy details come from AI — we just store the outcome here
model PolicyIssuance {
  id             String          @id @default(cuid())
  leadId         String
  lead           PolicyLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  policyName     String          // e.g. "PM Fasal Bima Yojana" — returned by AI
  policyProvider String?         // e.g. "Government of India"
  premiumAmount  Int?            // Annual premium in INR
  issuedAt       DateTime        @default(now())
  expiresAt      DateTime?
  status         IssuanceStatus  @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  nextPremiumDue DateTime?
}

model Message {
  id        String      @id @default(cuid())
  leadId    String
  lead      PolicyLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  policies  Json?
  createdAt DateTime    @default(now())
}

model Reminder {
  id          String       @id @default(cuid())
  leadId      String
  lead        PolicyLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        ReminderType
  scheduledAt DateTime
  note        String?
  isDone      Boolean      @default(false)
  createdAt   DateTime     @default(now())
}

model BirthdayReminder {
  id            String     @id @default(cuid())
  leadId        String
  lead          PolicyLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  dateOfBirth   DateTime
  daysUntil     Int        // 0 = today, 1-7 = this week, etc.
  isToday       Boolean    @default(false)
  wishSent      Boolean    @default(false)
  refreshedAt   DateTime   @default(now())
}

enum ReminderType {
  FOLLOWUP
  BIRTHDAY
}

enum MessageRole {
  AGENT
  AI
}

enum Role {
  AGENT
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  POLICY_ISSUED
  REJECTED
}

enum IssuanceStatus {
  ACTIVE
  EXPIRED
  CLAIMED
}